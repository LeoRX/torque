# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
# When the container runs on the same NAS as MariaDB, use host.docker.internal.
# The docker-compose.yml extra_hosts entry maps this to the NAS host gateway.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=torque
DB_PASS=your_db_password_here
DB_NAME=torque

# ── Web login (legacy creds.php array) ────────────────────────────────────────
# New accounts should be created via the torque_users DB table instead.
APP_USER=torque
APP_PASS=your_web_login_password_here

# ── Optional integrations ─────────────────────────────────────────────────────
# Google Maps API key (leave blank to disable map features)
GMAPS_API_KEY=

# Torque Pro device authentication (leave blank to allow any device to upload)
TORQUE_ID=
TORQUE_ID_HASH=
