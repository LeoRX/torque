# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
# When the container runs on the same NAS as MariaDB, use host.docker.internal.
# The docker-compose.yml extra_hosts entry maps this to the NAS host gateway.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=torque
DB_PASS=your_db_password_here
DB_NAME=torque

# ── Web login (legacy creds.php array) ────────────────────────────────────────
# New accounts should be created via the torque_users DB table instead.
APP_USER=torque
APP_PASS=your_web_login_password_here

# ── Optional integrations ─────────────────────────────────────────────────────
# Torque Pro device authentication (leave blank to allow any device to upload)
TORQUE_ID=
TORQUE_ID_HASH=

# Bearer token for HTTPS upload auth (enables Authorization header check in upload_data.php)
# Set this to require Torque Pro's Authorization header — enables safe HTTPS uploads.
# Generate with: openssl rand -hex 32   Leave blank to disable (HTTP upload still works).
BEARER_TOKEN=

# ── GPS repair scheduler (optional) ───────────────────────────────────────────
# The in-container scheduler runs the GPS repair job automatically. On/off and
# cadence are normally controlled in Settings → GPS Repair; these are ops overrides.
# GPS_REPAIR_CRON=0 hard-disables the scheduler loop regardless of the Settings toggle.
GPS_REPAIR_CRON=1
# How often (seconds) the loop checks whether a run is due (actual cadence = the
# Settings "Repair Schedule"). Default 300.
GPS_REPAIR_TICK=300
