# ── Secrets — NEVER commit these ─────────────────────────────────────────────
creds.php
.env

# ── Runtime-generated files ───────────────────────────────────────────────────
data/

# ── Python import scripts (local desktop tools, not part of the web app) ──────
# Run locally on Windows desktop — never part of the web app or public repo
*.py
*.pyc
__pycache__/

# ── OS cruft ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Claude Code IDE config + private deployment notes ────────────────────────
# CLAUDE.md is committed (sanitised public version — no private info)
# .claude/ contains private deployment details — gitignored, local only
.claude/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
